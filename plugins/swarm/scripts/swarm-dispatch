#!/usr/bin/env bash
# swarm-dispatch — create git worktrees + tmux panes/windows for N branches.
#
# For each branch, ensures a worktree exists at:
#   ${SWARMY_WORKTREE_BASE:-<parent-of-main-worktree>}/<repo>--<branch>
# then spawns a tmux pane (default) or window in that worktree path.
#
# SWARMY_WORKTREE_BASE may be absolute (used as-is) or relative (resolved
# against the main worktree, enabling in-repo worktrees like ".swarmy/wt").
#
# Prints the new tmux pane/window IDs on stdout (one per line, in the same
# order as the input branches). The caller is responsible for any further
# action inside the new pane/window (e.g. writing CHUNK.md and `tmux
# send-keys`); this script intentionally runs nothing in the new pane to
# preserve the race-avoidance sequencing of the swarm skill.
#
# Replaces fish helpers `tslw` (panes) and `tslwm` (windows).
#
# Usage:
#   swarm-dispatch [--mode panes|windows] <branch1> [branch2 ...]

set -euo pipefail

: "${CLAUDE_PLUGIN_ROOT:=$(cd "$(dirname "$0")/.." && pwd)}"

usage() {
    echo "Usage: swarm-dispatch [--mode panes|windows] <branch1> [branch2 ...]" >&2
    exit 1
}

mode="panes"
branches=()

while [ $# -gt 0 ]; do
    case "$1" in
        --mode)
            shift
            [ $# -gt 0 ] || usage
            mode="$1"
            shift
            ;;
        --mode=*)
            mode="${1#--mode=}"
            shift
            ;;
        -h|--help)
            usage
            ;;
        --)
            shift
            while [ $# -gt 0 ]; do
                branches+=("$1")
                shift
            done
            ;;
        -*)
            echo "swarm-dispatch: unknown option: $1" >&2
            usage
            ;;
        *)
            branches+=("$1")
            shift
            ;;
    esac
done

case "$mode" in
    panes|windows) ;;
    *)
        echo "swarm-dispatch: --mode must be 'panes' or 'windows' (got '$mode')" >&2
        exit 1
        ;;
esac

if [ "${#branches[@]}" -lt 1 ]; then
    usage
fi

if [ -z "${TMUX:-}" ]; then
    echo "swarm-dispatch: \$TMUX is not set; run from inside a tmux session" >&2
    exit 1
fi

common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || {
    echo "swarm-dispatch: not inside a git repository" >&2
    exit 1
}
# Canonicalize: cd into common_dir's parent (the main worktree).
main_abs=$(cd "$common_dir/.." && pwd -P)
base=$(basename "$main_abs")
parent=$(dirname "$main_abs")
wt_base_raw="${SWARMY_WORKTREE_BASE:-$parent}"
# Relative SWARMY_WORKTREE_BASE → resolve against the main worktree
# (enables in-repo placement like ".swarmy/worktrees"). Absolute → as-is.
case "$wt_base_raw" in
    /*) wt_base="$wt_base_raw" ;;
    *)  wt_base="$main_abs/$wt_base_raw" ;;
esac

# 1. Create or verify worktrees, silently.
wt_paths=()
for branch in "${branches[@]}"; do
    wt_path="$wt_base/$base--$branch"
    if [ ! -d "$wt_path" ]; then
        # First try to create with a new branch; if that fails (branch may
        # already exist), check out the existing branch into the worktree.
        # Capture stderr from the fallback so the user gets git's diagnostic
        # (e.g. "branch already used by worktree at …", "path is not empty")
        # instead of a generic "failed to create worktree".
        if ! git -C "$main_abs" worktree add -b "$branch" "$wt_path" >/dev/null 2>&1; then
            err=$(git -C "$main_abs" worktree add "$wt_path" "$branch" 2>&1 >/dev/null) && rc=0 || rc=$?
            if [ "$rc" -ne 0 ]; then
                echo "swarm-dispatch: failed to create worktree for '$branch' at $wt_path" >&2
                if [ -n "$err" ]; then
                    printf '  git: %s\n' "$err" >&2
                fi
                exit 1
            fi
        fi
    fi
    wt_paths+=("$wt_path")
done

# 2. Spawn panes or windows; print IDs in input order.
case "$mode" in
    panes)
        split_target="${TMUX_PANE:-}"
        if [ -z "$split_target" ]; then
            # Fallback: ask tmux for the active pane id.
            split_target=$(tmux display-message -p '#{pane_id}')
        fi
        first_pane=""
        i=0
        while [ "$i" -lt "${#wt_paths[@]}" ]; do
            wt="${wt_paths[$i]}"
            new_pane=$(tmux split-window -h -t "$split_target" -c "$wt" -P -F "#{pane_id}")
            echo "$new_pane $wt"
            if [ -z "$first_pane" ]; then
                first_pane="$new_pane"
            fi
            split_target="$new_pane"
            tmux select-layout -t "${TMUX_PANE:-$first_pane}" tiled >/dev/null
            i=$((i + 1))
        done
        if [ -n "$first_pane" ]; then
            tmux select-pane -t "$first_pane" >/dev/null
        fi
        ;;
    windows)
        i=0
        while [ "$i" -lt "${#wt_paths[@]}" ]; do
            wt="${wt_paths[$i]}"
            branch="${branches[$i]}"
            # `tmux new-window -P -F "#{pane_id}"` returns the pane id of the
            # new window's initial pane. We surface that — callers (and the
            # SKILL prose) treat it as the addressable target for send-keys.
            new_id=$(tmux new-window -c "$wt" -n "$branch" -P -F "#{pane_id}")
            echo "$new_id $wt"
            i=$((i + 1))
        done
        ;;
esac

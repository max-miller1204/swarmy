#!/usr/bin/env bash
# swarm-cherry-pick — fold commits from a worktree branch onto integration.
#
# Cherry-picks every commit on <branch> that is ahead of the integration
# branch (whatever the main worktree currently has checked out) onto the
# integration branch in the main worktree.
#
# Source-worktree resolution:
#   - If <branch> is given, source = ${SWARMY_WORKTREE_BASE:-<parent>}/<repo>--<branch>
#   - If no arg and called from inside a non-main worktree, source = pwd -P
#     and branch = current branch in that worktree.
#
# On conflict, prints a resume/abort hint and exits with cherry-pick's
# non-zero status. The user (or the SKILL) resolves in the main worktree
# and continues from there.
#
# Replaces the fish helper `gwc`.
#
# Usage: swarm-cherry-pick [<branch>]

set -euo pipefail

: "${CLAUDE_PLUGIN_ROOT:=$(cd "$(dirname "$0")/.." && pwd)}"

usage() {
    echo "Usage: swarm-cherry-pick [<branch>]" >&2
    exit 1
}

case "${1:-}" in
    -h|--help) usage ;;
esac

common_dir_raw=$(git rev-parse --git-common-dir 2>/dev/null) || {
    echo "swarm-cherry-pick: not inside a git repository" >&2
    exit 1
}
common_dir=$(cd "$common_dir_raw" && pwd -P)
main_abs=$(cd "$common_dir/.." && pwd -P)
base=$(basename "$main_abs")
parent=$(dirname "$main_abs")
wt_base_raw="${SWARMY_WORKTREE_BASE:-$parent}"
# Relative SWARMY_WORKTREE_BASE → resolve against the main worktree
# (enables in-repo placement like ".swarmy/worktrees"). Absolute → as-is.
case "$wt_base_raw" in
    /*) wt_base="$wt_base_raw" ;;
    *)  wt_base="$main_abs/$wt_base_raw" ;;
esac

branch=""
source_abs=""

if [ $# -gt 0 ] && [ -n "$1" ]; then
    branch="$1"
    source_abs="$wt_base/$base--$branch"
    if [ ! -d "$source_abs" ]; then
        echo "swarm-cherry-pick: no worktree found at $source_abs" >&2
        exit 1
    fi
else
    git_dir_raw=$(git rev-parse --git-dir 2>/dev/null) || exit 1
    resolved_git_dir=$(cd "$git_dir_raw" && pwd -P)
    if [ "$resolved_git_dir" = "$common_dir" ]; then
        echo "swarm-cherry-pick: already in the main worktree; pass a branch name to cherry-pick" >&2
        exit 1
    fi
    branch=$(git branch --show-current 2>/dev/null) || exit 1
    if [ -z "$branch" ]; then
        echo "swarm-cherry-pick: current worktree is detached; cannot determine source branch" >&2
        exit 1
    fi
    source_abs=$(pwd -P)
fi

target=$(git -C "$main_abs" branch --show-current 2>/dev/null || true)
if [ -z "$target" ]; then
    echo "swarm-cherry-pick: main worktree is detached; cannot determine target branch" >&2
    exit 1
fi
if [ "$target" = "$branch" ]; then
    echo "swarm-cherry-pick: '$branch' is already checked out in the main worktree" >&2
    exit 1
fi

# Newline-delimited list of commits, oldest first.
commits=$(git -C "$main_abs" rev-list --reverse "$target..$branch")
if [ -z "$commits" ]; then
    echo "swarm-cherry-pick: no commits on '$branch' ahead of '$target' — use swarm-apply for uncommitted diffs"
    exit 0
fi

# Count and preview.
n=$(printf '%s\n' "$commits" | wc -l | tr -d ' ')
echo "Cherry-picking $n commit(s) from '$branch' onto '$target':"
while IFS= read -r c; do
    [ -z "$c" ] && continue
    git -C "$main_abs" log -1 --oneline "$c"
done <<EOF
$commits
EOF

# Build a positional-arg list of commits (oldest first).
commit_args=()
while IFS= read -r c; do
    [ -z "$c" ] && continue
    commit_args+=("$c")
done <<EOF
$commits
EOF

# Don't trip set -e — we want to surface the cherry-pick exit code with a hint.
set +e
git -C "$main_abs" cherry-pick "${commit_args[@]}"
rc=$?
set -e

if [ "$rc" -ne 0 ]; then
    # Distinguish "real conflict" from "commits already applied" (an empty
    # cherry-pick — happens when the user re-runs swarm-cherry-pick on a
    # branch that's already been folded). On the empty path, git leaves
    # CHERRY_PICK_HEAD set with no diff to resolve, which is confusing
    # state to dump on the user. Auto-abort it and surface a clearer
    # message; the working tree is left clean so the next run isn't
    # blocked by the cleanliness check.
    git_dir=$(git -C "$main_abs" rev-parse --git-dir 2>/dev/null)
    if [ -n "$git_dir" ] && [ -e "$git_dir/CHERRY_PICK_HEAD" ] \
            && [ -z "$(git -C "$main_abs" status --porcelain --untracked-files=no)" ]; then
        git -C "$main_abs" cherry-pick --abort >/dev/null 2>&1 || true
        echo ""
        echo "swarm-cherry-pick: commits from '$branch' are already on '$target' (empty cherry-pick)."
        echo "  Aborted automatically. If you meant to fold a different branch, re-run with that branch name."
        echo "  If '$branch' is fully folded, run swarm-fold-cleanup '$branch' to tear it down."
        exit 0
    fi
    echo ""
    echo "swarm-cherry-pick: cherry-pick stopped. Resolve in $main_abs, then:"
    echo "  git -C $main_abs add <files>"
    echo "  git -C $main_abs cherry-pick --continue"
    echo "Or abort: git -C $main_abs cherry-pick --abort"
    exit "$rc"
fi

echo "Cherry-picked into $main_abs"
